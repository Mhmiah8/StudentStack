# Trackr scraper
TRACKR_SEASON=2026
TRACKR_REGION=UK
TRACKR_INDUSTRY=Technology
TRACKR_API_URL=https://api.the-trackr.com/programmes
TRACKR_TIMEOUT_SECONDS=30
TRACKR_REQUEST_INTERVAL_SECONDS=2
TRACKR_REFERER=https://app.the-trackr.com/uk-technology/summer-internships
# TRACKR_USER_AGENT=Mozilla/5.0 ...

# Luma scraper
LUMA_API_URL=https://api2.luma.com/discover/get-paginated-events
LUMA_TIMEOUT_SECONDS=30
LUMA_REQUEST_INTERVAL_SECONDS=1
LUMA_LATITUDE=51.50853
LUMA_LONGITUDE=-0.12574
LUMA_PAGE_LIMIT=50
LUMA_MAX_PAGES_PER_SLUG=3
# LUMA_USER_AGENT=Mozilla/5.0 ...
# LUMA_CLIENT_VERSION=abfcc89aa17f63cefb8adcc7385cb48c27bc8c95
# LUMA_WEB_URL=https://luma.com/tech
# Optional if Luma needs cookies in future:
# LUMA_COOKIES_JSON={"cookie_name":"cookie_value"}

# UCAS scraper
UCAS_BASE_URL=https://www.ucas.com
UCAS_SEARCH_URL=https://www.ucas.com/explore/search/scholarships-and-bursaries
UCAS_TIMEOUT_SECONDS=30
UCAS_REQUEST_INTERVAL_SECONDS=2
UCAS_PAGES=5
